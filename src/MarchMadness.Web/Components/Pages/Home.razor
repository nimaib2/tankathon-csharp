@page "/"
<PageTitle>March Madness Bracket Simulator</PageTitle>

<div class="hero">
    <h1>March Madness Bracket Simulator</h1>
    <p class="lead">2025-26 NCAA Men's Basketball. View the bracket and run simulations.</p>
    <p>
        <a href="/bracket" class="btn btn-primary">View Bracket</a>
        <a href="/bracket/simulate" class="btn btn-secondary">Simulate Tournament</a>
    </p>
</div>

<style>
    .hero { text-align: center; padding: 3rem 1rem; }
    .hero h1 { font-size: 2rem; margin-bottom: 0.5rem; }
    .lead { color: #555; margin-bottom: 1.5rem; }
    .btn { display: inline-block; padding: 0.6rem 1.2rem; margin: 0 0.25rem; border-radius: 6px; text-decoration: none; font-weight: 500; }
    .btn-primary { background: #c41e3a; color: #fff; }
    .btn-secondary { background: #0d2137; color: #fff; }
</style>

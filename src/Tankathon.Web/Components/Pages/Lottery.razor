@page "/lottery"
@rendermode InteractiveServer
@using Tankathon.Core.Models
@using Tankathon.Web.Services
@inject TankathonApiClient Api

<PageTitle>Lottery Simulator</PageTitle>

<h1>NBA Draft Lottery Simulator</h1>

<p class="text-muted">Run a random draft lottery based on current standings. Season: <strong>@_season</strong></p>

<div class="mb-3">
    <button class="btn btn-primary" @onclick="RunOne" disabled="@_running">Run simulation</button>
</div>

@if (_running)
{
    <p><em>Running...</em></p>
}
@if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}
@if (_lastResult is not null)
{
    <h2 class="h5 mt-4">Draft order</h2>
    <div class="table-responsive">
        <table class="table table-sm">
            <thead>
                <tr>
                    <th>Pick</th>
                    <th>Team</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in _lastResult.Picks.OrderBy(x => x.Pick))
                {
                    <tr>
                        <td>@p.Pick</td>
                        <td>@p.TeamName <span class="text-muted">(@p.Abbreviation)</span></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
@code {
    private string _season = "2025-26";
    private bool _running;
    private string? _error;
    private DraftOrderResult? _lastResult;

    private async Task RunOne()
    {
        _running = true;
        _error = null;
        _lastResult = null;
        try
        {
            _lastResult = await Api.SimulateLotteryAsync(_season);
        }
        catch (Exception ex)
        {
            _error = "Simulation failed. Is the API running? " + ex.Message;
        }
        finally
        {
            _running = false;
        }
    }
}

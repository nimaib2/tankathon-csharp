@page "/standings"
@rendermode InteractiveServer
@using Tankathon.Core.Models
@using Tankathon.Web.Services
@inject TankathonApiClient Api

<PageTitle>Lottery Standings</PageTitle>

<h1>NBA Draft Lottery Standings</h1>

@if (_loading)
{
    <p><em>Loading standings...</em></p>
}
else if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}
else
{
    <p class="text-muted">Worst 14 teams (lottery-eligible). Season: <strong>@_season</strong></p>
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Rank</th>
                    <th>Team</th>
                    <th>W</th>
                    <th>L</th>
                    <th>Win %</th>
                    <th>Odds #1</th>
                    <th>Odds Top 4</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in _standings)
                {
                    <tr>
                        <td>@s.Rank</td>
                        <td>@s.TeamName <span class="text-muted">(@s.Abbreviation)</span></td>
                        <td>@s.Wins</td>
                        <td>@s.Losses</td>
                        <td>@s.WinPercentage.ToString("P1")</td>
                        <td>@s.OddsForFirstPick.ToString("P1")</td>
                        <td>@s.OddsForTopFour.ToString("P1")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private string _season = "2024-25";
    private List<TeamStanding> _standings = new();
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            _standings = (await Api.GetStandingsAsync(_season)).ToList();
        }
        catch (Exception ex)
        {
            _error = "Could not load standings. Make sure the API is running (Tankathon.Api on http://localhost:5111). " + ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }
}
